{
  "name": "ecolint",
  "displayName": "EcoLint",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.114.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ecolint.helloWorld",
        "title": "EcoLint: Say Hello"
      },
      {
        "command": "ecolint.optimize",
        "title": "EcoLint: Optimize with Gemini"
      },
      {
        "command": "ecolint.listModels",
        "title": "EcoLint: List Available Models"
      }
    ],
    "configuration": {
      "title": "EcoLint",
      "properties": {
        "ecolint.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "API Key for Google Gemini (Generative AI) to power code optimizations."
        },
        "ecolint.modelId": {
          "type": "string",
          "default": "gemini-2.5-flash",
          "description": "The specific Gemini model ID to use for optimizations. Use the 'List Available Models' command to discover valid IDs for your account."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/lodash.debounce": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.114.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@google/generative-ai": "^0.24.1",
    "@tgwf/co2": "^0.18.0",
    "lodash.debounce": "^4.0.8"
  }
}
